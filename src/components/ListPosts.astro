---
import CardGrid from './CardGrid.astro';
import CardList from './CardList.astro';

const { posts, h1, showH1 = true } = Astro.props;

const chunks: { posts: typeof posts; type: 'grid' | 'left' | 'right' }[] = [];
for (let i = 0; i < posts.length; i += 3) {
    const ci = Math.floor(i / 3);
    const type = ci % 2 === 0 ? 'grid' : (Math.floor(ci / 2) % 2 === 0 ? 'left' : 'right');
    chunks.push({ posts: posts.slice(i, i + 3), type });
}
---

{ showH1 && <h1 class='mx-auto max-w-4xl px-5 pt-10 pb-6 text-center text-3xl font-extrabold text-white'>{h1}</h1> }

<div class='mx-auto max-w-4xl px-5'>
    <div class='py-5 flex flex-col gap-5'>
        {chunks.map((chunk) => {
            const hasAnyImage = chunk.posts.some(p => !!p.data.heroImage);
            if (chunk.type === 'grid') {
                return (
                    <div class='chunk grid grid-cols-1 sm:grid-cols-3 gap-5'>
                        {chunk.posts.map(post => (
                            <CardGrid
                                href={`/posts/${post.id}/`}
                                image={post.data.heroImage}
                                showImage={hasAnyImage}
                                title={post.data.title}
                                description={post.data.description}
                                date={post.data.pubDate}
                                tags={post.data.tags}
                            />
                        ))}
                    </div>
                );
            } else {
                return (
                    <div class='chunk flex flex-col gap-5'>
                        {chunk.posts.map(post => (
                            <CardList
                                href={`/posts/${post.id}/`}
                                image={post.data.heroImage}
                                showImage={hasAnyImage}
                                title={post.data.title}
                                description={post.data.description}
                                date={post.data.pubDate}
                                tags={post.data.tags}
                                reverse={chunk.type === 'right'}
                            />
                        ))}
                    </div>
                );
            }
        })}
    </div>
</div>
