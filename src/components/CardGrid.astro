---
import { Image } from 'astro:assets';
import PostTags from './PostTags.astro';
import { formatDate } from '../utils/format';
import type { ImageMetadata } from 'astro';

interface Props {
    href: string;
    image: ImageMetadata;
    title: string;
    description?: string;
    date?: Date;
    tags?: string;
}
const { href, image, title, description, date, tags } = Astro.props;
---

<a class='card-v relative flex flex-col bg-brand-card overflow-hidden hover:opacity-75 transition-opacity duration-200'
   href={href} data-tags={tags}>
    { tags && (
        <div class='absolute top-2 left-2 flex flex-wrap gap-1 z-10'>
            <PostTags tags={tags} />
        </div>
    )}
    <div class='overflow-hidden'>
        <Image class='w-full object-cover' loading='lazy' width={800} height={400} src={image} alt={title} />
    </div>
    <div class='p-4 flex flex-col flex-1'>
        { date && <div class='text-xs text-gray-500 mb-1 font-semibold'>{formatDate(date)}</div> }
        <h2 class='text-base font-bold text-white leading-snug mb-1'>{title}</h2>
        { description && <p class='text-xs text-gray-400 mt-auto line-clamp-2'>{description}</p> }
    </div>
</a>
