---
interface Props {
    currentPage: number;
    totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

function pageUrl(page: number) {
    return page === 1 ? '/' : `/page/${page}/`;
}

// Построить список страниц с "..." для пропусков
const pages: (number | null)[] = [];
for (let i = 1; i <= totalPages; i++) {
    if (
        i === 1 ||
        i === totalPages ||
        (i >= currentPage - 2 && i <= currentPage + 2)
    ) {
        pages.push(i);
    } else if (pages[pages.length - 1] !== null) {
        pages.push(null); // разделитель
    }
}
---

<nav class='flex items-center justify-center gap-1 py-8' aria-label='Pagination'>
    { currentPage > 1 && (
        <a href={pageUrl(currentPage - 1)}
           class='flex items-center justify-center w-9 h-9 rounded bg-brand-surface text-gray-400 hover:text-white hover:bg-white/10 transition-colors'
           aria-label='Предыдущая'>
            <svg width='16' height='16' viewBox='0 0 16 16' fill='none'>
                <path d='M10 3L5 8L10 13' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/>
            </svg>
        </a>
    )}

    { pages.map(page =>
        page === null ? (
            <span class='flex items-center justify-center w-9 h-9 text-gray-600 text-sm select-none'>…</span>
        ) : page === currentPage ? (
            <span class='flex items-center justify-center w-9 h-9 rounded bg-brand-accent text-white text-sm font-semibold'>{page}</span>
        ) : (
            <a href={pageUrl(page)}
               class='flex items-center justify-center w-9 h-9 rounded bg-brand-surface text-gray-400 hover:text-white hover:bg-white/10 transition-colors text-sm'>
                {page}
            </a>
        )
    )}

    { currentPage < totalPages && (
        <a href={pageUrl(currentPage + 1)}
           class='flex items-center justify-center w-9 h-9 rounded bg-brand-surface text-gray-400 hover:text-white hover:bg-white/10 transition-colors'
           aria-label='Следующая'>
            <svg width='16' height='16' viewBox='0 0 16 16' fill='none'>
                <path d='M6 3L11 8L6 13' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/>
            </svg>
        </a>
    )}
</nav>
