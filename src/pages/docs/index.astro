---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DOCS_TITLE, DOCS_DESCR, DOCS_OG_IMAGE, DOCS_H1 } from '../../consts';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const docs_hub: Record<string, { url: string; thumb: string; order: number; title: string; description: string }> = {};

for (const doc of docs) {
    const group = doc.id.split('/')[0];
    if (!docs_hub[group] || docs_hub[group].order > doc.data.order) {
        docs_hub[group] = {
            url:   `/docs/${group}/`,
            thumb: `/res/docs/${group}.webp`,
            order: doc.data.order,
            title: doc.data.title,
            description: doc.data.description,
        };
    }
}
---

<BaseLayout title={DOCS_TITLE} description={DOCS_DESCR} og_image={DOCS_OG_IMAGE} ld_json="{}">
    <div class='mx-auto max-w-4xl px-5'>
        <h1 class='pt-10 pb-6 text-center text-3xl font-extrabold text-white'>{DOCS_H1}</h1>
        <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 py-6'>
            { Object.values(docs_hub).map(item => (
                <a class='flex flex-col bg-brand-card overflow-hidden hover:opacity-75 transition-opacity duration-200' href={item.url}>
                    <img class='w-full bg-brand-surface' loading='lazy' width={800} height={400} src={item.thumb} alt={item.title} />
                    <div class='p-4 flex flex-col flex-1'>
                        <h2 class='text-base font-bold text-white leading-snug mb-1'>{item.title}</h2>
                        <p class='text-xs text-gray-400 mt-auto line-clamp-2'>{item.description}</p>
                    </div>
                </a>
            )) }
        </div>
    </div>
</BaseLayout>
