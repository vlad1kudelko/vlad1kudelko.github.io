---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BannerMini from '../../components/BannerMini.astro';
import PostTags from '../../components/PostTags.astro';
import { formatDate } from '../../utils/format';
import { AUTHOR_NAME } from '../../consts';

import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

const post = Astro.props;
const { Content } = await render(post);

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": post.data.title }
    ]
},{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    ...(post.data.heroImage ? { "image": [ post.data.heroImage.src ] } : {}),
    "datePublished": post.data.pubDate.toISOString(),
    "author": [{ "@type": "Person", "name": AUTHOR_NAME, "url": Astro.site }]
}];

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    if (posts.length > 5) {
        for (let key_current in posts) {
            key_current = Number(key_current);
            const other_keys = [
                key_current - 2 >= 0           ? key_current - 2 : posts.length + key_current - 2,
                key_current - 1 >= 0           ? key_current - 1 : posts.length + key_current - 1,
                key_current + 1 < posts.length ? key_current + 1 : key_current - posts.length + 1,
                key_current + 2 < posts.length ? key_current + 2 : key_current - posts.length + 2,
            ];
            posts[key_current].other_pages = other_keys.map(k => ({
                title: posts[k].data.title,
                url:   '/posts/' + posts[k].id + '/',
                img:   posts[k].data.heroImage,
            }));
        }
    }
    return posts.map(post => ({ params: { slug: post.id }, props: post }));
}
---

<BaseLayout title={post.data.title} description={post.data.description} og_image={post.data.heroImage?.src} ld_json={JSON.stringify(json_ld)}>
    <div class='mx-auto max-w-3xl'>

        { post.data.heroImage && <Image class='w-full bg-brand-surface' loading='lazy' width={800} height={400} src={post.data.heroImage} alt={post.data.title} /> }

        <BannerMini />

        <div class='p-5 bg-brand-card'>
            <div class='flex flex-wrap gap-1 mb-3'>
                <PostTags tags={post.data.tags} />
            </div>
            <div class='text-xs text-gray-500 font-semibold mb-4'>{formatDate(post.data.pubDate)}</div>
            <div class='prose prose-invert max-w-none marker:text-gray-400'>
                <Content />
            </div>
        </div>

        { post.data.github && (
            <div class='p-5 bg-brand-card border-t border-white/5'>
                <a class='flex items-center gap-4 p-4 bg-brand-surface rounded-lg hover:opacity-80 transition-opacity' rel='nofollow' href={post.data.github}>
                    <img class='size-8' src='/res/all/github.webp' alt='github' />
                    <div class='font-semibold text-sm text-gray-300 break-all'>{post.data.github}</div>
                </a>
            </div>
        )}

        { post.other_pages && (
            <div class='p-5 bg-brand-card border-t border-white/5'>
                <h2 class='text-2xl text-center font-extrabold mb-6 text-white'>Читайте также</h2>
                <div class='grid grid-cols-2 gap-4'>
                    { post.other_pages.map(p => (
                        <a href={p.url} class='block hover:opacity-80 transition-opacity'>
                            { p.img
                                ? <Image class='w-full' loading='lazy' width={800} height={400} src={p.img} alt={p.title} />
                                : <div class='w-full aspect-[2/1] bg-brand-surface' />
                            }
                            <div class='text-sm text-gray-300 mt-2 leading-snug'>{p.title}</div>
                        </a>
                    )) }
                </div>
            </div>
        )}

        <div class='p-5 bg-brand-card border-t border-white/5'>
            <a target='_blank' rel='nofollow' href='/go/timeweb-cloud'>
                <img loading='lazy' src='/res/all/timeweb.webp' alt='timeweb-cloud' />
            </a>
        </div>

    </div>
</BaseLayout>
