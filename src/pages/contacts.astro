---
import BaseLayout from '../layouts/BaseLayout.astro';

import { TELEGRAM_CHANNEL } from '../consts';

const title = 'Контакты';
const description = 'Наши контактные данные';

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": title }
    ]
}];
---

<BaseLayout title={title} description={description} og_image="/res/all/thumb2.webp" ld_json={JSON.stringify(json_ld)}>
    <div class='mx-auto max-w-3xl'>
        <!-- contacts -->
        <div class='p-8 flex justify-center'>
            <img class='rounded-full size-24' src='/res/all/logo.webp' alt='logo' />
        </div>
        <div class='p-5 bg-brand-card'>
            <div class='prose prose-invert max-w-none text-center'>
                <h1>Контакты</h1>
                <p>Для вопросов и предложений:</p>
                <div class='bg-brand-surface p-3 rounded-lg mb-2'>
                    <a href='mailto:vlad1kudelko@gmail.com'>Email</a>
                </div>
                <p>Не забывайте подписаться на нас в других социальных сетях:</p>
                <div class='grid grid-cols-2 gap-2'>
                    <div class='bg-brand-surface p-3 rounded-lg'> <a href='https://www.youtube.com/@crafthomelab'>YouTube</a> </div>
                    <div class='bg-brand-surface p-3 rounded-lg'> <a href={TELEGRAM_CHANNEL}>Telegram</a> </div>
                    <div class='bg-brand-surface p-3 rounded-lg'> <a href='https://dzen.ru/crafthomelab'>Dzen</a> </div>
                    <div class='bg-brand-surface p-3 rounded-lg'> <a href='https://rutube.ru/channel/68763186/'>RuTube</a> </div>
                </div>
            </div>
        </div>
        <!-- contacts -->
    </div>
</BaseLayout>
