---
import BaseLayout from '../layouts/BaseLayout.astro';

import { TELEGRAM_CHANNEL } from '../consts';

const title = 'Контакты';
const description = 'Наши контактные данные';

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": title }
    ]
}];
---

<BaseLayout title={title} description={description} og_image="/res/all/thumb2.webp" ld_json={JSON.stringify(json_ld)}>
    <div class='mx-auto max-w-3xl'>
        <!-- contacts -->
        <div class='p-8 flex justify-center'>
            <img class='rounded-full size-24' src='/res/all/logo.webp' alt='logo' />
        </div>
        <div class='p-5 bg-brand-card'>
            <h1 class='text-2xl font-extrabold text-white text-center mb-6'>Контакты</h1>
            <p class='text-sm text-gray-400 text-center mb-3'>Для вопросов и предложений:</p>
            <a class='block bg-brand-surface px-4 py-3 rounded-lg text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-150 mb-6' href='mailto:vlad1kudelko@gmail.com'>Email</a>
            <p class='text-sm text-gray-400 text-center mb-3'>Не забывайте подписаться на нас в других социальных сетях:</p>
            <div class='grid grid-cols-2 gap-2'>
                <a class='block bg-brand-surface px-4 py-3 rounded-lg text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-150' href='https://www.youtube.com/@crafthomelab'>YouTube</a>
                <a class='block bg-brand-surface px-4 py-3 rounded-lg text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-150' href={TELEGRAM_CHANNEL}>Telegram</a>
                <a class='block bg-brand-surface px-4 py-3 rounded-lg text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-150' href='https://dzen.ru/crafthomelab'>Dzen</a>
                <a class='block bg-brand-surface px-4 py-3 rounded-lg text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-150' href='https://rutube.ru/channel/68763186/'>RuTube</a>
            </div>
        </div>
        <!-- contacts -->
    </div>
</BaseLayout>
