---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListPosts from '../components/ListPosts.astro';

import { INDEX_TITLE, INDEX_DESCR, INDEX_OG_IMAGE, INDEX_H1 } from '../consts';

import { getCollection } from 'astro:content';

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home" },
    ]
}];

const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={INDEX_TITLE} description={INDEX_DESCR} og_image={INDEX_OG_IMAGE} ld_json={JSON.stringify(json_ld)}>
    <ListPosts posts={posts} level={2} h1={INDEX_H1} />
</BaseLayout>
