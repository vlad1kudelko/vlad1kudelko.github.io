---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListPosts from '../components/ListPosts.astro';
import Pagination from '../components/Pagination.astro';

import { INDEX_TITLE, INDEX_DESCR, INDEX_OG_IMAGE, INDEX_H1, POSTS_PER_PAGE } from '../consts';

import { getCollection } from 'astro:content';

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home" },
    ]
}];

const allPosts = (await getCollection('posts')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title={INDEX_TITLE} description={INDEX_DESCR} og_image={INDEX_OG_IMAGE} ld_json={JSON.stringify(json_ld)}>
    <ListPosts posts={posts} h1={INDEX_H1} />
    { totalPages > 1 && <Pagination currentPage={1} totalPages={totalPages} /> }
</BaseLayout>
