---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListPosts from '../components/ListPosts.astro';

import { SITE_TITLE, SITE_DESCRIPTION, HOME_H1 } from '../consts';

import { getCollection } from 'astro:content';

const json_ld = [{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home" },
    ]
}];

const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} og_image="/res/all/thumb.webp" ld_json={JSON.stringify(json_ld)}>
    <ListPosts posts={posts} level={2} h1={HOME_H1} />
</BaseLayout>
